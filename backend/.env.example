# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Get your connection string from https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Use a long random string — e.g.: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
ALLOWED_ORIGINS=https://price-comparision-agent.onrender.com

# ─── Groq (AI Chat) ──────────────────────────────────────────────────────────
# Get your key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ─── SerpAPI (product search) ────────────────────────────────────────────────
# Get your key from https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# ─── Scraper tuning (optional) ───────────────────────────────────────────────
SCRAPER_TIMEOUT=15000
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_RETRY_DELAY=2000

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to use Ethereal (fake) transport in dev/test
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
